          <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>

      <a href="/super_admin/manage_teachers"
        class="flex items-center gap-5 bg-[#2e2e2c] border border-[#40403C] hover:border-[#f0460d]/30 rounded-xl px-6 py-5 text-white group cursor-pointer">
        <div class="w-11 h-11 rounded-xl bg-[#3a3a38] border border-[#40403C] group-hover:border-[#f0460d]/20 flex items-center justify-center shrink-0 transition-colors duration-300">
