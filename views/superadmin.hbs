<script>
  const changePassword = document.getElementById("changePassword");
  const changePasswordModal = document.getElementById("changePasswordModal");
  const closePasswordModal = document.getElementById("closePasswordModal");

  changePassword.addEventListener("click", () => {
    changePasswordModal.classList.remove("hidden");
  });

  closePasswordModal.addEventListener("click", () => {
    changePasswordModal.classList.add("hidden");
  });
  
  let hideState = false

  const hideShow = document.getElementById("hideShow");
  const showPassword = document.getElementById("showPassword");
  const newPassword = document.getElementById("newPassword");

  hideShow.addEventListener("click", () => {

    if (!hideState){
      showPassword.textContent = "Hide";
      hideState = true;
      newPassword.type = "text";
    }
    else{
      showPassword.textContent = "Show";
      hideState = false;
      newPassword.type = "password";
    }
  })

  const superAdminId = document.getElementById("superAdminId");
  console.log(superAdminId);
  const loader = document.getElementById("loader");

  const savePasswordBtn = document.getElementById("savePasswordBtn");

  savePasswordBtn.addEventListener("click", async () => {

    const delay = (ms) => new Promise(resolve => setTimeout(resolve, ms));

    const start = Date.now();
    const elapsed = Date.now() - start;

    loader.classList.remove("hidden");
    console.log("clicked");
    const id = superAdminId.value;

    const response = await fetch("/super_admin/change_password", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ id: id, newPassword: newPassword.value })
    });

    const data = await response.json();
    
    if (response.ok && data.success){
      console.log("Successfully updated the password");
      if (elapsed < 1500) {
        await delay(1500 - elapsed);
      }
      loader.classList.add("hidden");
      changePasswordModal.classList.add("hidden");
      newPassword.value = "";

      alert("Successfully updated the password!");
    }
    else {
      if (elapsed < 1500) {
        await delay(1500 - elapsed);
      }
      loader.classList.add("hidden");
      changePasswordModal.classList.add("hidden");
      console.log("Failed to update the password");
      newPassword.value = "";
      alert("Failed to change the password!");
    }
    
  })
</script>