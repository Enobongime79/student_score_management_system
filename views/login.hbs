<div class="flex flex-col items-center font-[Google_Sans_Flex] justify-center bg-[#262624] min-h-screen">

  <div class="fixed inset-0 pointer-events-none z-0 opacity-[0.025]" style="background-image:url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22/%3E%3C/svg%3E');background-size:200px"></div>

  <style>
    .input-field {
      background: #1e1e1c;
      border: 1px solid #40403C;
      color: white;
      border-radius: 10px;
      height: 46px;
      padding: 0 14px;
      width: 100%;
      font-family: inherit;
      font-size: 14px;
      transition: border-color 0.2s, box-shadow 0.2s;
      outline: none;
    }
    .input-field:focus {
      border-color: #f0460d;
      box-shadow: 0 0 0 3px rgba(240,70,13,0.12);
    }
    .input-field::placeholder { color: #555552; }

    .password-wrapper {
      background: #1e1e1c;
      border: 1px solid #40403C;
      border-radius: 10px;
      height: 46px;
      display: flex;
      align-items: center;
      padding: 0 14px;
      transition: border-color 0.2s, box-shadow 0.2s;
    }
    .password-wrapper:focus-within {
      border-color: #f0460d;
      box-shadow: 0 0 0 3px rgba(240,70,13,0.12);
    }
    .password-wrapper input {
      background: transparent;
      border: none;
      outline: none;
      color: white;
      font-family: inherit;
      font-size: 14px;
      width: 100%;
      height: 100%;
    }
  </style>

  <form action="/login" method="POST"
    class="relative z-10 flex flex-col text-white w-[92vw] sm:w-[420px] bg-[#2e2e2c] border border-[#40403C] rounded-2xl px-8 py-10 shadow-2xl">

    <div class="flex flex-col items-center mb-8">
      <div class="w-12 h-12 rounded-xl bg-[#f0460d]/15 border border-[#f0460d]/25 flex items-center justify-center mb-4">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#f0460d" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/>
        </svg>
      </div>
      <h1 class="text-white text-2xl font-medium">Welcome back</h1>
      <p class="text-[#555552] text-xs mt-1">Student Score Manager</p>
    </div>

    <div class="flex flex-col gap-1.5 mb-4">
      <div class="flex items-center justify-between">
        <label for="email" class="text-xs text-[#888885] font-medium tracking-wide uppercase">Email</label>
        <p class="text-red-400 text-xs">{{emailErr}}</p>
      </div>
      <input type="text" name="email" id="email" placeholder="you@school.edu" class="input-field">
    </div>

    <div class="flex flex-col gap-1.5 mb-6">
      <div class="flex items-center justify-between">
        <label for="password" class="text-xs text-[#888885] font-medium tracking-wide uppercase">Password</label>
        <p class="text-red-400 text-xs">{{passwordErr}}</p>
      </div>
      <div class="password-wrapper">
        <input id="password" type="password" name="password" placeholder="••••••••">
        <button type="button" id="showPasswordBtn" class="ml-2 flex-shrink-0 text-[#555552] hover:text-[#f0460d] transition-colors duration-200 cursor-pointer">
          <svg id="eyeOpen" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
          </svg>
          <svg id="eyeClosed" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden">
            <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/>
            <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/>
            <line x1="1" y1="1" x2="23" y2="23"/>
          </svg>
        </button>
      </div>
    </div>

    <button type="submit"
      class="bg-[#f0460d] hover:bg-[#d03c0b] text-white font-medium py-3 rounded-xl text-sm cursor-pointer transition-colors duration-200 flex items-center justify-center gap-2">
      Sign In
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
      </svg>
    </button>
  </form>
</div>

<script>
  const showPasswordBtn = document.getElementById("showPasswordBtn");
  const eyeOpen = document.getElementById("eyeOpen");
  const eyeClosed = document.getElementById("eyeClosed");
  const password = document.getElementById("password");

  let showPasswordState = false;

  showPasswordBtn.addEventListener("click", () => {
    if (showPasswordState == false) {
      eyeOpen.classList.add("hidden");
      eyeClosed.classList.remove("hidden");
      showPasswordState = true;
      password.type = "text";
    } else {
      eyeOpen.classList.remove("hidden");
      eyeClosed.classList.add("hidden");
      showPasswordState = false;
      password.type = "password";
    }
  });
</script>