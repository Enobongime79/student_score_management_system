<div class="min-h-screen bg-[#262624] font-[Google_Sans_Flex]">

  <div class="fixed inset-0 pointer-events-none z-0 opacity-[0.025]" style="background-image:url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22/%3E%3C/svg%3E');background-size:200px"></div>
  <nav class="relative z-10 flex items-center lg:mx-16 mx-5 py-5 border-b border-[#40403C]">
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 rounded-lg bg-[#f0460d]/15 border border-[#f0460d]/25 flex items-center justify-center shrink-0">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#f0460d" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/>
        </svg>
      </div>
      <div>
        <p class="text-white text-sm lg:text-base font-medium leading-none">Student Score Manager</p>
        <p class="text-[#555552] text-xs mt-0.5 leading-none">Students Directory</p>
      </div>
    </div>
    <button id="addStudent"
      class="ms-auto text-xs lg:text-sm text-white font-medium rounded-lg bg-[#f0460d] hover:bg-[#d03c0b] px-4 py-2.5 flex items-center gap-2 cursor-pointer transition-colors duration-200">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
      Add Student
    </button>
  </nav>

  <div id="modal" class="fixed hidden text-white bg-[rgba(0,0,0,0.75)] backdrop-blur-sm font-[Google_Sans_Flex] top-0 left-0 flex-row items-center justify-center z-50 w-screen h-screen">
    <div class="bg-[#262624] border border-[#40403C] w-[92vw] sm:w-120 rounded-xl p-6 shadow-2xl">
      <div class="flex items-center justify-between mb-5 pb-4 border-b border-[#40403C]">
        <div>
          <p class="text-white text-sm font-medium">New Student</p>
          <p class="text-[#555552] text-xs mt-0.5">Fill in the student's details</p>
        </div>
        <button id="closeModal" class="action-btn ml-4">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#888885" stroke-width="2.5" stroke-linecap="round">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>
      <form action="/super_admin/manage_students/add_student" method="POST" class="flex flex-col gap-4">
        <div class="flex flex-col gap-1.5">
          <label for="fullName" class="text-xs text-[#888885] font-medium tracking-wide uppercase">Full Name</label>
          <input name="fullName" id="fullName" type="text" placeholder="e.g. Jane Smith" class="border border-[#40403C] focus:outline-none px-2 py-2 text-sm rounded">
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div class="flex flex-col gap-1.5">
            <label for="grade" class="text-xs text-[#888885] font-medium tracking-wide uppercase">Grade (1–12)</label>
            <input name="grade" id="grade" type="number" placeholder="1 – 12" class="border border-[#40403C] focus:outline-none px-2 py-2 text-sm rounded">
          </div>
          <div class="flex flex-col gap-1.5">
            <label for="mathScore" class="text-xs text-[#888885] font-medium tracking-wide uppercase">Math Score</label>
            <input name="mathScore" id="mathScore" type="number" placeholder="0 – 100" class="border border-[#40403C] focus:outline-none px-2 py-2 text-sm rounded">
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div class="flex flex-col gap-1.5">
            <label for="englishScore" class="text-xs text-[#888885] font-medium tracking-wide uppercase">English Score</label>
            <input name="englishScore" id="englishScore" type="number" placeholder="0 – 100" class="border border-[#40403C] focus:outline-none px-2 py-2 text-sm rounded">
          </div>
          <div class="flex flex-col gap-1.5">
            <label for="scienceScore" class="text-xs text-[#888885] font-medium tracking-wide uppercase">Science Score</label>
            <input name="scienceScore" id="scienceScore" type="number" placeholder="0 – 100" class="border border-[#40403C] focus:outline-none px-2 py-2 text-sm rounded">
          </div>
        </div>
        <button type="submit"
          class="mt-2 bg-[#f0460d] hover:bg-[#d03c0b] text-white text-sm font-medium py-2.5 rounded-lg cursor-pointer transition-colors duration-200 flex items-center justify-center gap-2">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
            <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
          </svg>
          Add Student
        </button>
      </form>
    </div>
  </div>

  <!-- EDIT Modal -->
  <div id="editModal" class="fixed hidden text-white bg-[rgba(0,0,0,0.75)] backdrop-blur-sm font-[Google_Sans_Flex] top-0 left-0 flex-row items-center justify-center z-50 w-screen h-screen">
    <div class="bg-[#262624] border border-[#40403C] w-[92vw] sm:w-120 rounded-xl p-6 shadow-2xl">
      <div class="flex items-center justify-between mb-5 pb-4 border-b border-[#40403C]">
        <div>
          <p class="text-white text-sm font-medium">Edit Student</p>
          <p class="text-[#555552] text-xs mt-0.5">Update the student's information</p>
        </div>
        <button id="closeEditModal" class="action-btn ml-4">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#888885" stroke-width="2.5" stroke-linecap="round">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>
      <form action="/super_admin/manage_students/save_details" method="POST" class="flex flex-col gap-4">
        <div class="flex flex-col gap-1.5">
          <label for="editFullName" class="text-xs text-[#888885] font-medium tracking-wide uppercase">Full Name</label>
          <input name="fullName" id="editFullName" type="text" placeholder="Full Name" class="border border-[#40403C] focus:outline-none px-2 py-2 text-sm rounded">
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div class="flex flex-col gap-1.5">
            <label for="editGrade" class="text-xs text-[#888885] font-medium tracking-wide uppercase">Grade (1–12)</label>
            <input name="grade" id="editGrade" type="number" placeholder="1 – 12" class="border border-[#40403C] focus:outline-none px-2 py-2 text-sm rounded">
          </div>
          <div class="flex flex-col gap-1.5">
            <label for="editMathScore" class="text-xs text-[#888885] font-medium tracking-wide uppercase">Math Score</label>
            <input name="mathScore" id="editMathScore" type="number" placeholder="0 – 100" class="border border-[#40403C] focus:outline-none px-2 py-2 text-sm rounded">
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div class="flex flex-col gap-1.5">
            <label for="editEnglishScore" class="text-xs text-[#888885] font-medium tracking-wide uppercase">English Score</label>
            <input name="englishScore" id="editEnglishScore" type="number" placeholder="0 – 100" class="border border-[#40403C] focus:outline-none px-2 py-2 text-sm rounded">
          </div>
          <div class="flex flex-col gap-1.5">
            <label for="editScienceScore" class="text-xs text-[#888885] font-medium tracking-wide uppercase">Science Score</label>
            <input name="scienceScore" id="editScienceScore" type="number" placeholder="0 – 100" class="border border-[#40403C] focus:outline-none px-2 py-2 text-sm rounded">
          </div>
        </div>
        <input id="real_id" type="hidden" name="real_id">
        <button id="saveBtn" type="submit"
          class="mt-2 bg-[#f0460d] hover:bg-[#d03c0b] text-white text-sm font-medium py-2.5 rounded-lg cursor-pointer transition-colors duration-200 flex items-center justify-center gap-2">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/>
          </svg>
          Save Changes
        </button>
      </form>
    </div>
  </div>

  <main class="relative z-10 lg:mx-16 mx-5 py-8">
    <div class="mb-6">
      <p class="text-[#f0460d] text-xs font-medium tracking-[0.18em] uppercase mb-0.5">Records</p>
      <h2 class="text-white text-xl font-medium">Students</h2>
    </div>

    <div class="border border-[#40403C] rounded-xl overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-white">
          <thead>
            <tr class="bg-[#2e2e2c] border-b border-[#40403C]">
              <th class="text-left px-4 py-3.5 text-xs font-medium text-[#888885] tracking-wider uppercase whitespace-nowrap">Name</th>
              <th class="text-left px-4 py-3.5 text-xs font-medium text-[#888885] tracking-wider uppercase whitespace-nowrap">Student ID</th>
              <th class="text-left px-4 py-3.5 text-xs font-medium text-[#888885] tracking-wider uppercase whitespace-nowrap">Grade</th>
              <th class="text-center px-4 py-3.5 text-xs font-medium text-[#888885] tracking-wider uppercase whitespace-nowrap">Math</th>
              <th class="text-center px-4 py-3.5 text-xs font-medium text-[#888885] tracking-wider uppercase whitespace-nowrap">English</th>
              <th class="text-center px-4 py-3.5 text-xs font-medium text-[#888885] tracking-wider uppercase whitespace-nowrap">Science</th>
              <th class="text-center px-4 py-3.5 text-xs font-medium text-[#888885] tracking-wider uppercase whitespace-nowrap">Total</th>
              <th class="text-center px-4 py-3.5 text-xs font-medium text-[#888885] tracking-wider uppercase whitespace-nowrap">Average</th>
              <th class="text-center px-4 py-3.5 text-xs font-medium text-[#888885] tracking-wider uppercase whitespace-nowrap">Actions</th>
            </tr>
          </thead>
          <tbody>
            {{#each students}}
            <tr class="table-row border-b hover:bg-[#322A25] border-[#40403C] last:border-b-0">
              <td class="px-4 py-3.5">
                <span class="text-sm text-white font-medium whitespace-nowrap">{{this.name}}</span>
              </td>
              <td class="px-4 py-3.5">
                <span class="text-center text-xs p-1 bg-gray-700 rounded">{{this.real_id}}</span>
              </td>
              <td class="px-4 py-3.5">
                <span class="text-xs text-orange-600 rounded py-1 px-2 border border-orange-600">{{this.class}}</span>
              </td>
              <td class="px-4 py-3.5 text-center">
                <span class="text-xs rounded py-1 px-2 math_value">{{this.math}}</span>
              </td>
              <td class="px-4 py-3.5 text-center">
                <span class="text-xs rounded py-1 px-2 english_value">{{this.english}}</span>
              </td>
              <td class="px-4 py-3.5 text-center">
                <span class="text-xs rounded py-1 px-2 science_value">{{this.science}}</span>
              </td>
              <td class="px-4 py-3.5 text-center">
                <span class="text-sm text-white font-medium">{{this.total}}</span>
              </td>
              <td class="px-4 py-3.5 text-center">
                <span class="text-sm text-[#c2c0b6]">{{this.average}}</span>
              </td>
              <td class="px-4 py-3.5">
                <div class="flex items-center justify-center gap-2">
                  <button data-id="{{this.id}}" class="editBtn action-btn" title="Edit student">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#888885" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                      <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                    </svg>
                  </button>
                  <form action="/super_admin/manage_students/delete_student" method="post">
                    <input type="hidden" name="id" value="{{this.id}}">
                    <button type="submit" class="deleteBtn action-btn hover:border-red-700/50! hover:bg-red-900/20!" title="Delete student">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#888885" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
                        <path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
                      </svg>
                    </button>
                  </form>
                </div>
              </td>
            </tr>
            {{/each}}
          </tbody>
        </table>
      </div>

      <div class="{{#if students}}hidden{{/if}} flex flex-col items-center justify-center py-16 text-center">
        <div class="w-12 h-12 rounded-xl bg-[#2e2e2c] border border-[#40403C] flex items-center justify-center mb-4">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#555552" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/>
          </svg>
        </div>
        <p class="text-[#888885] text-sm font-medium">No students yet</p>
        <p class="text-[#555552] text-xs mt-1">Click "Add Student" to get started</p>
      </div>
    </div>
  </main>
</div>

<script>
  const mathScore = document.getElementById("mathScore");
  const englishScore = document.getElementById("englishScore");
  const scienceScore = document.getElementById("scienceScore");
  const averageScore = document.getElementById("averageScore");
  const totalScore = document.getElementById("totalScore");

  const max = 100;
  const min = 0;

  mathScore.addEventListener("blur", () => {
    if (mathScore.value != "") {
      if (parseInt(mathScore.value) < min) mathScore.value = min;
      if (parseInt(mathScore.value) > max) mathScore.value = max;
    }
  });

  englishScore.addEventListener("blur", () => {
    if (englishScore.value != "") {
      if (parseInt(englishScore.value) < min) englishScore.value = min;
      if (parseInt(englishScore.value) > max) englishScore.value = max;
    }
  });

  scienceScore.addEventListener("blur", () => {
    if (scienceScore.value != "") {
      if (parseInt(scienceScore.value) < min) scienceScore.value = min;
      if (parseInt(scienceScore.value) > max) scienceScore.value = max;
    }
  });

  const grade = document.getElementById("grade");
  const maxGrade = 12;
  const minGrade = 1;

  grade.addEventListener("blur", () => {
    if (grade.value != "") {
      if (parseInt(grade.value) < minGrade) grade.value = minGrade;
      if (parseInt(grade.value) > maxGrade) grade.value = maxGrade;
    }
  });

  const modal = document.getElementById("modal");
  const closeModal = document.getElementById("closeModal");
  const addStudent = document.getElementById("addStudent");

  closeModal.addEventListener("click", () => {
    modal.classList.remove("flex");
    modal.classList.add("hidden");
  });

  addStudent.addEventListener("click", () => {
    modal.classList.remove("hidden");
    modal.classList.add("flex");
  });

  const deleteBtns = document.querySelectorAll(".deleteBtn");
  deleteBtns.forEach(button => {
    button.addEventListener("click", (event) => {
      if (!confirm('Are you sure you want to delete that row?')) {
        event.preventDefault();
      }
    });
  });

  const editModal = document.getElementById("editModal");
  const closeEditModal = document.getElementById("closeEditModal");

  const editFullName = document.getElementById("editFullName");
  const editGrade = document.getElementById("editGrade");
  const editMathScore = document.getElementById("editMathScore");
  const editEnglishScore = document.getElementById("editEnglishScore");
  const editScienceScore = document.getElementById("editScienceScore");
  const real_id = document.getElementById("real_id");

  closeEditModal.addEventListener("click", () => {
    editModal.classList.remove("flex");
    editModal.classList.add("hidden");
  });

  const editBtns = document.querySelectorAll(".editBtn");

  editBtns.forEach(button => {
    button.addEventListener("click", async () => {
      const id = button.dataset.id;

      const response = await fetch("/super_admin/manage_students/edit_student", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ id: id })
      });

      const data = await response.json();
      console.log(data);

      editFullName.value = data['name'];
      real_id.value = data['id'];
      editMathScore.value = data['math'];
      editEnglishScore.value = data['english'];
      editScienceScore.value = data['science'];
      editGrade.value = parseInt(data['class'].replace("Grade ", ""));

      editModal.classList.remove("hidden");
      editModal.classList.add("flex");
    });
  });

  const math_values = document.querySelectorAll(".math_value");
  const english_values = document.querySelectorAll(".english_value");
  const science_values = document.querySelectorAll(".science_value");

  math_values.forEach(
    row => {
      if (parseInt(row.innerText) > 75){
        row.classList.add('bg-green-500')
      }
      if ((parseInt(row.innerText) < 75) && (parseInt(row.innerText) >= 45)){
        row.classList.add('bg-yellow-500')
      }
      if (parseInt(row.innerText) < 45){
        row.classList.add('bg-red-500')
      }
    }
  )

  english_values.forEach(
    row => {
      if (parseInt(row.innerText) > 75){
        row.classList.add('bg-green-500')
      }
      if ((parseInt(row.innerText) < 75) && (parseInt(row.innerText) >= 45)){
        row.classList.add('bg-yellow-500')
      }
      if (parseInt(row.innerText) < 45){
        row.classList.add('bg-red-500')
      }
    }
  )

  science_values.forEach(
    row => {
      if (parseInt(row.innerText) > 75){
        row.classList.add('bg-green-500')
      }
      if ((parseInt(row.innerText) < 75) && (parseInt(row.innerText) >= 45)){
        row.classList.add('bg-yellow-500')
      }
      if (parseInt(row.innerText) < 45){
        row.classList.add('bg-red-500')
      }
    }
  )

</script>